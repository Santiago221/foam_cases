internalField   uniform 0;

boundaryField
{
    tpms
    {
        type            zeroGradient;
    }
    nozzle
    {
        type            zeroGradient;
    }
    inlet
    {
        type            zeroGradient;
    }
    outlet
    {
        type            zeroGradient;
    }
}


